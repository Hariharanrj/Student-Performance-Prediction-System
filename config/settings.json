{
  "app": {
    "name": "Student Performance Prediction System",
    "version": "1.0.0",
    "author": "AI & Data Science Department",
    "description": "ML-powered student academic performance predictor with Explainable AI"
  },
  "database": {
    "host": "localhost",
    "port": 3306,
    "name": "student_performance_db",
    "charset": "utf8mb4"
  },
  "model": {
    "default": "best_model",
    "retrain_threshold_days": 30
  },
  "risk": {
    "high_threshold": 0.70,
    "medium_threshold": 0.40
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "max_bytes": 10485760,
    "backup_count": 5
  },
  "email": {
    "enabled": false,
    "alert_batch_size": 10
  },
  "ui": {
    "records_per_page": 25,
    "chart_theme": "plotly_white"
  }
}
